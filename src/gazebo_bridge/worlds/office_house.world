<?xml version="1.0" ?>
<sdf version="1.7">
  <world name="office_house">
    <gravity>0 0 -9.8</gravity>
    <include>
      <uri>model://ground_plane</uri>
    </include>
    <include>
      <uri>model://sun</uri>
    </include>

    <model name="perimeter_walls">
