        </collision>
        <visual name="room_north_visual">
          <pose>1.5 2.5 1.25 0 0 0</pose>
          <geometry><box><size>5.0 0.2 2.5</size></box></geometry>
          <material><ambient>0.85 0.78 0.67 1</ambient></material>
        </visual>
        <visual name="room_west_visual">
          <pose>-1.0 1.0 1.25 0 0 0</pose>
          <geometry><box><size>0.2 3.0 2.5</size></box></geometry>
          <material><ambient>0.85 0.78 0.67 1</ambient></material>
        </visual>
        <visual name="room_east_visual">
