          <geometry><box><size>14 0.25 2.5</size></box></geometry>
          <material><ambient>0.72 0.72 0.72 1</ambient></material>
        </visual>
        <visual name="east_wall_visual">
          <pose>7 0 1.25 0 0 0</pose>
          <geometry><box><size>0.25 12 2.5</size></box></geometry>
          <material><ambient>0.72 0.72 0.72 1</ambient></material>
        </visual>
        <visual name="west_wall_visual">
          <pose>-7 0 1.25 0 0 0</pose>
          <geometry><box><size>0.25 12 2.5</size></box></geometry>
          <material><ambient>0.72 0.72 0.72 1</ambient></material>
        </visual>
      </link>
    </model>

    <model name="inner_room">
      <static>true</static>
      <link name="room_walls">
        <collision name="room_north">
          <pose>1.5 2.5 1.25 0 0 0</pose>
          <geometry><box><size>5.0 0.2 2.5</size></box></geometry>
        </collision>
        <collision name="room_west">
          <pose>-1.0 1.0 1.25 0 0 0</pose>
